<%- include('partials_header') %><h1>API Keys</h1><section class="card"><h2>Create API Key</h2><form method="post" action="/api-keys"><input name="name" placeholder="Website key"><% if(user.role==='admin'){ %><label>User</label><select name="userId"><% users.forEach(u=>{ %><option value="<%= u.id %>"><%= u.email %></option><% }) %></select><% } %><label>Permissions</label><div class="checks"><% permissions.forEach(p=>{ %><label><input type="checkbox" name="permissions" value="<%= p %>"> <%= p %></label><% }) %></div><button class="primary">Create Key</button></form><p class="warn">Copy the full key when it appears. It is only shown once.</p></section><section class="card"><h2>Saved Keys</h2><table><tr><th>Name</th><th>Prefix</th><th>Permissions</th><th></th></tr><% keys.forEach(k=>{ %><tr><td><%= k.name %></td><td><%= k.prefix %></td><td><%= k.permissions.join(', ') %></td><td><form method="post" action="/api-keys/<%= k.id %>/delete"><button>Revoke</button></form></td></tr><% }) %></table></section><%- include('partials_footer') %>
