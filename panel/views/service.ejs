<%- include('partials_header') %><div class="service-head"><div><h1><%= service.name %></h1><p class="muted"><%= service.kind %> · <%= service.server_type || 'VPS' %> <%= service.game_version || '' %> · <%= service.ip_address || '' %>:<%= service.port || '' %></p></div><div class="actions"><form method="post" action="/services/<%= service.id %>/start"><button>Start</button></form><form method="post" action="/services/<%= service.id %>/stop"><button>Stop</button></form><form method="post" action="/services/<%= service.id %>/restart"><button>Restart</button></form></div></div>
<div class="tabs"><a href="#console">Console</a><a href="#files">Files</a><a href="#backups">Backups</a><a href="#saves">Saves</a><a href="#network">Network Ports</a><a href="#subdomains">Subdomains</a><a href="#databases">Databases</a><a href="#subusers">Subusers</a><a href="#settings">Settings/Delete</a><% if(service.kind==='vps'){ %><a href="#vps">VPS</a><% } %></div>
<section id="console" class="card"><h2>Live Console</h2><pre id="logs" class="console">Loading...</pre><form id="cmdForm" class="row"><input id="cmd" placeholder="type command"><button>Send</button></form></section>
<section id="files" class="card"><h2>File Manager</h2><div class="row"><input id="filePath" placeholder="folder path"><button onclick="loadFiles();return false;">Open</button><button onclick="selectAllFiles();return false;">Select all</button><button onclick="deleteSelected();return false;">Delete selected</button></div><div id="fileList"></div></section>
<section id="backups" class="card"><h2>Backups</h2><form method="post" action="/services/<%= service.id %>/backups/create"><button class="primary">Create Backup</button></form><div id="backupList">Loading...</div></section>
<section id="saves" class="card"><h2>Saves / Worlds</h2><a class="btn" href="/services/<%= service.id %>/files/download?path=world">Download world folder/archive</a><p class="muted">Upload world files from the File Manager. ZIP/TAR world upload can be extended in the agent.</p></section>
<section id="network" class="card"><h2>Network Ports</h2><form method="post" action="/services/<%= service.id %>/network" class="row"><input name="port" type="number" placeholder="Port"><select name="protocol"><option>tcp</option><option>udp</option></select><input name="notes" placeholder="Notes"><button>Add port record</button></form><table><tr><th>Port</th><th>Protocol</th><th>Notes</th></tr><% ports.forEach(p=>{ %><tr><td><%= p.port %></td><td><%= p.protocol %></td><td><%= p.notes %></td></tr><% }) %></table><p class="warn">Adding a port record saves it in the panel. Recreating Docker port bindings can be added next per node policy.</p></section>
<section id="subdomains" class="card"><h2>Subdomains</h2><form method="post" action="/services/<%= service.id %>/subdomains" class="stack"><label>Use Outback domain prefix</label><input name="prefix" placeholder="myserver"><label><input type="checkbox" name="useOwnDomain" value="true"> Use my own domain</label><input name="hostname" placeholder="play.example.com for own domain"><input name="target" value="<%= service.ip_address || '' %>" placeholder="Target"><input name="port" value="<%= service.port || '' %>"><button>Add domain</button></form><table><tr><th>Hostname</th><th>Target</th><th>Status</th></tr><% subs.forEach(s=>{ %><tr><td><%= s.hostname %></td><td><%= s.target %>:<%= s.port %></td><td><%= s.status %></td></tr><% }) %></table><p class="muted">Users need subdomain slots before adding domains. Own domains are saved and shown with DNS target info.</p></section>
<section id="databases" class="card"><h2>Databases</h2><form method="post" action="/services/<%= service.id %>/databases" class="row"><input name="name" placeholder="database name"><select name="engine"><option>postgres</option><option>mysql</option></select><input name="host" placeholder="host"><input name="port" placeholder="5432"><button>Create DB record</button></form><table><tr><th>Name</th><th>Engine</th><th>User</th><th>Host</th></tr><% databases.forEach(d=>{ %><tr><td><%= d.name %></td><td><%= d.engine %></td><td><%= d.username %></td><td><%= d.host %>:<%= d.port %></td></tr><% }) %></table><p class="warn">One database per server. This stores database credentials; automatic DB-server creation can be wired to your Postgres/MySQL host.</p></section>
<section id="subusers" class="card"><h2>Subusers</h2><form method="post" action="/services/<%= service.id %>/subusers" class="row"><select name="userId"><% users.forEach(u=>{ %><option value="<%= u.id %>"><%= u.email %></option><% }) %></select><label><input name="permissions" value="console" type="checkbox"> Console</label><label><input name="permissions" value="files" type="checkbox"> Files</label><label><input name="permissions" value="backups" type="checkbox"> Backups</label><button>Add/update</button></form><table><tr><th>User</th><th>Permissions</th></tr><% subusers.forEach(su=>{ %><tr><td><%= su.email %></td><td><%= su.permissions.join(', ') %></td></tr><% }) %></table></section>
<% if(service.kind==='vps'){ %><section id="vps" class="card"><h2>VPS Manage</h2><p>IP: <%= service.ip_address %> SSH Port: <%= service.port %></p><p>RAM: <%= service.memory_mb %> MB · Storage: <%= service.storage_mb %> MB</p><form method="post" action="/services/<%= service.id %>/factory-reset" onsubmit="return confirm('This wipes VPS data. Continue?')"><button class="danger">Factory Reset VPS</button></form></section><% } %>
<section id="settings" class="card"><h2>Settings / Delete</h2><p>Resource changes and Docker recreate can be extended from here.</p><form method="post" action="/services/<%= service.id %>/delete" onsubmit="return confirm('Delete this service?')"><label><input type="checkbox" name="deleteFiles" value="true"> Delete files too</label><button class="danger">Delete Server</button></form></section>
<script>window.SERVICE_ID='<%= service.id %>';</script><%- include('partials_footer') %>
