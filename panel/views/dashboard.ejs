<%- include('partials_header') %><h1>Dashboard</h1><p class="muted">Manage your game servers and container VPS services.</p><div class="grid"><% services.forEach(s=>{ %><a class="card service" href="/services/<%= s.id %>"><h2><%= s.name %></h2><p><%= s.kind %> · <%= s.server_type || 'VPS' %> <%= s.game_version || '' %></p><p>RAM <%= s.memory_mb %> MB · Storage <%= s.storage_mb %> MB · Port <%= s.port || '-' %></p><span class="pill"><%= s.status %></span></a><% }) %></div><% if(!services.length){ %><div class="card"><p>No services yet. Admin can create one from the Admin page.</p></div><% } %><%- include('partials_footer') %>
