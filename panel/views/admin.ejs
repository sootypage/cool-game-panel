<%- include('partials_header') %><h1>Admin</h1><div class="tabs"><a href="#users">Users</a><a href="#nodes">Nodes</a><a href="#plans">Plans</a><a href="#provision">Create Service</a><a href="#audit">Audit</a></div>
<section id="users" class="card"><h2>Users</h2><form method="post" action="/admin/users" class="row"><input name="email" placeholder="email" required><input name="name" placeholder="name"><input name="password" placeholder="password"><select name="role"><option>user</option><option>admin</option></select><input name="subdomainSlots" type="number" placeholder="subdomain slots"><input name="databaseSlots" type="number" placeholder="database slots"><button>Add</button></form><table><tr><th>Email</th><th>Role</th><th>Slots</th><th>Update</th></tr><% users.forEach(u=>{ %><tr><td><%= u.email %></td><td><%= u.role %></td><td>Subdomains <%= u.subdomain_slots %> · DB <%= u.database_slots %></td><td><form method="post" action="/admin/users/<%= u.id %>/slots" class="row"><input name="subdomainSlots" type="number" value="<%= u.subdomain_slots %>"><input name="databaseSlots" type="number" value="<%= u.database_slots %>"><button>Save</button></form></td></tr><% }) %></table></section>
<section id="nodes" class="card"><h2>Docker Nodes</h2><form method="post" action="/admin/nodes" class="stack"><input name="name" placeholder="Node name" required><input name="url" placeholder="http://node-ip:4100" required><input name="token" placeholder="Agent token" required><input name="publicIp" placeholder="Public IP"><input name="location" placeholder="Location"><button class="primary">Add Node</button></form><table><tr><th>Name</th><th>URL</th><th>IP</th><th>Location</th></tr><% nodes.forEach(n=>{ %><tr><td><%= n.name %></td><td><%= n.url %></td><td><%= n.public_ip %></td><td><%= n.location %></td></tr><% }) %></table></section>
<section id="plans" class="card"><h2>Plans</h2><form method="post" action="/admin/plans" class="stack"><input name="name" placeholder="Plan name" required><select name="kind"><option value="game">Game Server</option><option value="vps">Container VPS</option></select><input name="priceCents" type="number" placeholder="Price cents"><input name="memoryMb" type="number" placeholder="RAM MB"><input name="storageMb" type="number" placeholder="Storage MB"><input name="cpuLimit" type="number" step="0.1" placeholder="CPU limit"><label>Game type</label><select name="serverType"><% gameTypes.forEach(t=>{ %><option value="<%= t %>"><%= t %></option><% }) %></select><label>Game version</label><select name="gameVersion"><% gameVersions.forEach(v=>{ %><option value="<%= v %>"><%= v %></option><% }) %></select><input name="dockerImage" placeholder="Custom Docker image optional"><input name="subdomainSlots" type="number" placeholder="Included subdomain slots"><input name="databaseSlots" type="number" placeholder="Included database slots"><button class="primary">Add Plan</button></form><table><tr><th>Name</th><th>Kind</th><th>RAM</th><th>Storage</th><th>Type</th><th>Version</th><th></th></tr><% plans.forEach(p=>{ %><tr><td><%= p.name %></td><td><%= p.kind %></td><td><%= p.memory_mb %></td><td><%= p.storage_mb %></td><td><%= p.server_type %></td><td><%= p.game_version %></td><td><form method="post" action="/admin/plans/<%= p.id %>/delete"><button>Delete</button></form></td></tr><% }) %></table></section>
<section id="provision" class="card"><h2>Create Service For User</h2><form method="post" action="/admin/provision" class="stack"><select name="ownerId"><% users.forEach(u=>{ %><option value="<%= u.id %>"><%= u.email %></option><% }) %></select><select name="nodeId"><% nodes.forEach(n=>{ %><option value="<%= n.id %>"><%= n.name %></option><% }) %></select><select name="planId"><% plans.forEach(p=>{ %><option value="<%= p.id %>"><%= p.name %> (<%= p.kind %>)</option><% }) %></select><input name="name" placeholder="Service name"><select name="serverType"><% gameTypes.forEach(t=>{ %><option value="<%= t %>"><%= t %></option><% }) %></select><select name="gameVersion"><% gameVersions.forEach(v=>{ %><option value="<%= v %>"><%= v %></option><% }) %></select><input name="port" type="number" placeholder="Public port"><button class="primary">Create</button></form></section>
<section id="audit" class="card"><h2>Audit</h2><table><tr><th>Action</th><th>When</th></tr><% audit.forEach(a=>{ %><tr><td><%= a.action %></td><td><%= a.created_at %></td></tr><% }) %></table></section><%- include('partials_footer') %>
